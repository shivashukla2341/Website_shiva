# =============================================================================
# Environment Variables — copy to .env.local and fill in real values.
# Vars prefixed NEXT_PUBLIC_ are shipped to the browser bundle: never put
# secrets there. Everything else stays server-only.
# See docs/ENVIRONMENT_VARIABLES.md for a full description of every key.
# =============================================================================

# --- App -----------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Website Shiva"
NODE_ENV=development

# --- Supabase --------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- Database (direct connection, used by Supabase CLI / migrations) -------
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# --- Auth: OAuth providers (configured in Supabase Auth dashboard, listed
# here only if you also call the provider APIs directly) -------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Payments: Razorpay ------------------------------------------------------
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Payments: Stripe --------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Media: Cloudinary -------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=

# --- Email: Resend ------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL="Website Shiva <orders@example.com>"

# --- AI --------------------------------------------------------------------
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-5

# --- Analytics ---------------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# --- Security ------------------------------------------------------------
CSRF_SECRET=
RATE_LIMIT_REDIS_URL=

# --- Notifications (architecture placeholders, see docs/ARCHITECTURE.md) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
WHATSAPP_BUSINESS_PHONE_ID=
WHATSAPP_BUSINESS_ACCESS_TOKEN=
WEB_PUSH_PUBLIC_VAPID_KEY=
WEB_PUSH_PRIVATE_VAPID_KEY=
